JavaScript
// GANTI DENGAN NOMOR WHATSAPP PENJUAL/AFILIATOR (Format: 628xxx)
const NOMOR_WA_PENJUAL = "6281234567890"; 

let keranjang = [];

// Helper untuk mengubah string harga (misal "Rp33.500") menjadi angka murni (33500)
function parsePrice(priceStr) {
  return parseInt(priceStr.replace(/[^0-9]/g, '')) || 0;
}

// Format angka ke format Rupiah (33500 -> Rp33.500)
function formatRupiah(number) {
  return "Rp" + number.toLocaleString('id-ID');
}

// 1. Fungsi Menambah Produk ke Keranjang
function tambahKeKeranjang(namaProduk) {
  const produk = daftarProduk.find(p => p.name === namaProduk);
  if (!produk) return;

  const itemAda = keranjang.find(item => item.name === namaProduk);
  if (itemAda) {
    itemAda.qty += 1;
  } else {
    keranjang.push({
      name: produk.name,
      priceStr: produk.price,
      priceNum: parsePrice(produk.price),
      qty: 1
    });
  }
  updateCartUI();
}

// 2. Fungsi Mengubah Jumlah (Qty)
function ubahQty(namaProduk, delta) {
  const item = keranjang.find(i => i.name === namaProduk);
  if (!item) return;

  item.qty += delta;
  if (item.qty <= 0) {
    keranjang = keranjang.filter(i => i.name !== namaProduk);
  }
  updateCartUI();
}

// 3. Update Tampilan Keranjang
function updateCartUI() {
  const cartCountEl = document.getElementById('cart-count');
  const cartListEl = document.getElementById('cart-items-list');
  const grandTotalEl = document.getElementById('cart-grand-total');

  let totalItemCount = 0;
  let grandTotal = 0;
  cartListEl.innerHTML = '';

  if (keranjang.length === 0) {
    cartListEl.innerHTML = '<p style="text-align:center; color:#777;">Keranjang masih kosong.</p>';
  } else {
    keranjang.forEach(item => {
      totalItemCount += item.qty;
      const subtotal = item.priceNum * item.qty;
      grandTotal += subtotal;

      const itemDiv = document.createElement('div');
      itemDiv.className = 'cart-item';
      itemDiv.innerHTML = `
        <div class="cart-item-info">
          <div class="cart-item-title">${item.name}</div>
          <div class="cart-item-price">${item.qty} x ${item.priceStr} = ${formatRupiah(subtotal)}</div>
        </div>
        <div class="cart-qty-control">
          <button class="btn-qty" onclick="ubahQty('${item.name}', -1)">-</button>
          <span>${item.qty}</span>
          <button class="btn-qty" onclick="ubahQty('${item.name}', 1)">+</button>
        </div>
      `;
      cartListEl.appendChild(itemDiv);
    });
  }

  cartCountEl.innerText = totalItemCount;
  grandTotalEl.innerText = formatRupiah(grandTotal);
}

// 4. Buka / Tutup Modal
function openCartModal() {
  document.getElementById('cart-modal').style.display = 'flex';
}

function closeCartModal() {
  document.getElementById('cart-modal').style.display = 'none';
}

// 5. Kirim via WhatsApp
function sendToWhatsApp() {
  if (keranjang.length === 0) {
    alert("Keranjang kamu masih kosong!");
    return;
  }

  let pesan = "*NOTA/BON TEMPO PEMBELIAN*\n";
  pesan += "-----------------------------------\n";
  
  let grandTotal = 0;
  keranjang.forEach((item, index) => {
    const subtotal = item.priceNum * item.qty;
    grandTotal += subtotal;
    pesan += `${index + 1}. ${item.name}\n   ${item.qty} x ${item.priceStr} = ${formatRupiah(subtotal)}\n`;
  });

  pesan += "-----------------------------------\n";
  pesan += `*TOTAL TAGIHAN: ${formatRupiah(grandTotal)}*\n\n`;
  pesan += "Mohon diproses, terima kasih!";

  const url = `https://wa.me/${NOMOR_WA_PENJUAL}?text=${encodeURIComponent(pesan)}`;
  window.open(url, '_blank');
}

// 6. Salin Ringkasan ke Clipboard
function copyCartSummary() {
  if (keranjang.length === 0) {
    alert("Keranjang kamu masih kosong!");
    return;
  }

  let teks = "NOTA PEMBELIAN:\n";
  let grandTotal = 0;
  keranjang.forEach((item, index) => {
    const subtotal = item.priceNum * item.qty;
    grandTotal += subtotal;
    teks += `${index + 1}. ${item.name} (${item.qty}x) = ${formatRupiah(subtotal)}\n`;
  });
  teks += `TOTAL: ${formatRupiah(grandTotal)}`;

  navigator.clipboard.writeText(teks).then(() => {
    alert("Ringkasan berhasil disalin ke clipboard!");
