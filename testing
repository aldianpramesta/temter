  <style>
    /* Mengimpor font dari Google Fonts */
    @import url('https://fonts.googleapis.com/css2?family=Instrument+Sans:wght@400;500;600;700&family=Instrument+Serif:ital@1&display=swap');

    body {
      margin: 0;
      background-color: #000; /* Warna latar belakang hitam */
      color: #ffffff; /* Warna teks default putih */
      font-family: 'Instrument Sans', sans-serif; /* Font utama */
    }

    section {
      width: 100%; /* Lebar penuh */
      display: flex; /* Flexbox layout */
      flex-direction: column; /* Susun elemen ke bawah */
      justify-content: center;
      align-items: center; /* Posisi tengah secara horizontal */
    }

    /* ========== Animasi Global ========== */
    @keyframes fadeIn {
      from { opacity: 0; transform: translateY(20px); }
      to { opacity: 1; transform: translateY(0); }
    }
    
    /* Section 1 - Judul Nama */
    .section-1 {
      height: auto; /* Otomatis mengikuti isi */
      padding: 32px 16px; /* Spasi atas bawah 32px, samping 16px */
      display: block; /* Supaya kontennya gak center (default block) */
    }
    .section-1 .judul {
      font-weight: bold;
      font-size: 16px;
      letter-spacing: -0.04em; /* Spasi antar huruf lebih rapat */
      line-height: 1em;
      padding-left: 20px;
    }
    .section-1 .temter {
      font-family: 'Instrument Serif', serif; /* Font khusus untuk TEMTER */
      font-style: italic;
      font-weight: 400;
    }

    /* Section 5 - Pricing Cards */
    .section-5 {
      height: auto; /* Diubah jadi otomatis mengikuti isi barang */
      padding: 60px 16px; /* Ditambah sedikit jarak atasnya biar gak nempel branding */
      display: flex;
      justify-content: flex-start; /* Dimulai normal dari atas ke bawah */
      align-items: center;
    }
    
    .pricing-wrapper {
        display: flex;
        gap: 12px 24px;
        width: 100%;
        max-width: 1200px;
        justify-content: space-between; 
        flex-wrap: wrap;
    }

    .product-name {
      font-weight: 600;
      font-size: 24px; /* <- Ubah ukuran semua teks produk di sini */
      margin-bottom: 15px;
      color: #ffffff;
    }
    
    .product-image-container {
      width: 100%;
      height: 200px;
      margin-bottom: 16px;
      display: flex;
      justify-content: center;
      align-items: center;
      overflow: hidden;
    }

    .product-image-container img {
      max-width: 100%;
      max-height: 100%;
      object-fit: contain;
    }
    
    .pricing-card {
      background-color: #111111;
      border-radius: 12px;
      padding: 24px;
      width: 100%;
      max-width: 360px;
      height: auto;
      box-sizing: border-box;
      display: flex;
      flex-direction: column;
      justify-content: flex-start;
    }

    .harga-durasi {
      display: flex;
      gap: 8px;
      align-items: baseline;
      margin-bottom: 45px;
    }

    .harga-durasi .harga {
      font-family: 'Instrument Sans', sans-serif;
      font-weight: 600;
      font-size: 18px;
      line-height: 10px;
      color: #808080;
    }

    .harga-durasi .durasi {
      font-family: 'Instrument Sans', sans-serif;
      font-weight: 500;
      font-size: 12px;
      letter-spacing: 0.8px;
      line-height: 15px;
      color: #808080;
    }

    /* Styling untuk Tombol Halaman (Pagination) */
    .pagination-wrapper-buttons {
      display: flex;
      justify-content: center;
      align-items: center;
      gap: 10px;
      margin-top: 40px;
      width: 100%;
    }

    .page-btn {
      background-color: #111111;
      color: #ffffff;
      border: 1px solid #333333;
      padding: 10px 18px;
      border-radius: 8px;
      cursor: pointer;
      font-weight: 600;
      font-size: 14px;
      transition: all 0.2s ease;
    }

    .page-btn.active {
      background-color: #ffffff;
      color: #000000;
      border-color: #ffffff;
    }

    .page-btn:hover:not(.active) {
      background-color: #222222;
      border-color: #555555;
    }

    /* ================= TAMPILAN KHUSUS HP (RESPONSIF) ================= */
    @media (max-width: 768px) {
        .pricing-wrapper {
            display: grid;
            grid-template-columns: repeat(3, 1fr); 
            gap: 8px;
            padding: 0 4px;
        }

        .pricing-card {
            height: auto;
            padding: 8px 8px 20px 8px;
            border-radius: 8px;
        }

        .product-image-container {
            height: 80px; 
            margin-bottom: 8px;
        }

        .product-name {
            font-size: 14px;
            line-height: 1.2em;
            margin-bottom: 10px;
        }

        .harga-durasi {
            margin-bottom: 0px;
        }

        .harga-durasi .harga {
            font-size: 13px;
        }
    }
    /* ========== STYLING KERANJANG & MODAL ========== */
    .cart-floating-btn { position: fixed; bottom: 20px; right: 20px; background-color: #ffffff; color: #000000; padding: 12px 20px; border-radius: 30px; font-weight: 700; font-size: 15px; border: none; cursor: pointer; box-shadow: 0 4px 15px rgba(255, 255, 255, 0.2); z-index: 99; display: flex; align-items: center; gap: 8px; transition: transform 0.2s; }
    .cart-floating-btn:hover { transform: scale(1.05); }
    .btn-add-cart { width: 100%; margin-top: 10px; background-color: #ffffff; color: #000000; border: none; padding: 8px; border-radius: 6px; font-weight: 600; font-size: 13px; cursor: pointer; transition: background 0.2s; }
    .btn-add-cart:hover { background-color: #dddddd; }
    .cart-modal { display: none; position: fixed; top: 0; left: 0; width: 100%; height: 100%; background-color: rgba(0, 0, 0, 0.85); z-index: 100; justify-content: center; align-items: center; padding: 16px; box-sizing: border-box; }
    .cart-content { background-color: #111111; border: 1px solid #333333; border-radius: 12px; width: 100%; max-width: 450px; max-height: 90vh; overflow-y: auto; padding: 20px; color: #ffffff; box-shadow: 0 8px 32px rgba(0, 0, 0, 0.5); }
    .cart-header { display: flex; justify-content: space-between; align-items: center; border-bottom: 1px solid #333333; padding-bottom: 12px; margin-bottom: 15px; }
    .cart-header h3 { margin: 0; font-size: 18px; }
    .close-cart-btn { background: none; border: none; color: #888888; font-size: 24px; cursor: pointer; }
    .close-cart-btn:hover { color: #ffffff; }
    .cart-item { display: flex; justify-content: space-between; align-items: center; padding: 10px 0; border-bottom: 1px solid #222222; }
    .cart-item-info { flex: 1; padding-right: 10px; }
    .cart-item-title { font-size: 13px; font-weight: 600; margin-bottom: 4px; }
    .cart-item-price { font-size: 12px; color: #888888; }
    .cart-qty-control { display: flex; align-items: center; gap: 8px; }
    .btn-qty { background: #222222; color: #ffffff; border: 1px solid #444444; width: 24px; height: 24px; border-radius: 4px; cursor: pointer; font-weight: bold; }
    .cart-total-box { display: flex; justify-content: space-between; font-size: 16px; font-weight: bold; padding: 15px 0; border-top: 2px solid #333333; margin-top: 15px; }
    .instruction-box { background-color: #1a1a1a; border: 1px dashed #555555; border-radius: 8px; padding: 12px; margin-bottom: 15px; font-size: 12px; color: #cccccc; line-height: 1.4; }
    .cart-actions { display: flex; flex-direction: column; gap: 8px; }
    .btn-wa { background-color: #25D366; color: #ffffff; border: none; padding: 12px; border-radius: 8px; font-weight: bold; font-size: 14px; cursor: pointer; text-align: center; }
    .btn-copy { background-color: #333333; color: #ffffff; border: 1px solid #555555; padding: 10px; border-radius: 8px; font-weight: 600; font-size: 13px; cursor: pointer; }
